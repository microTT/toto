    <key>StandardOutPath</key>
    <string>/Users/microTT/toto/local-service-atlas/logs/launchagent.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/microTT/toto/local-service-atlas/logs/launchagent.stderr.log</string>
