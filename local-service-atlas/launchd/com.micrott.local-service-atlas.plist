<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.micrott.local-service-atlas</string>

    <key>ProgramArguments</key>
    <array>
      <string>/opt/homebrew/bin/node</string>
      <string>/Users/microTT/toto/local-service-atlas/server.mjs</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/microTT/toto/local-service-atlas</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PORT</key>
      <string>9114</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ProcessType</key>
